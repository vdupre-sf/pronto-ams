  "title": "CollectionsDashboardSettings - Metadata API",
  "description": "Represents an org’s settings to add the Collections Dashboard application to an org.",
  "file_information": ".settings",
  "directory_location": "settings",
  "fields_columns": [
    "type",
    "description"
  ],
  "fields": {
    "enableCollectionsDashboard": {
      "type": "boolean",
      "description": "Indicates whether to add the Collections Dashboard application to an org (true) or not (false). The default value is false."
    }
  },
  "wsdl_segment": "```xml\n<xsd:complexType name=\"CollectionsDashboardSettings\">\n  <xsd:complexContent>\n    <xsd:extension base=\"tns:Metadata\">\n      <xsd:sequence>\n        <xsd:element name=\"enableCollectionsDashboard\" minOccurs=\"0\" type=\"xsd:boolean\"/>\n      </xsd:sequence>\n    </xsd:extension>\n  </xsd:complexContent>\n</xsd:complexType>\n```",
