# Copy to .env and fill in. Never commit the real .env.
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_CLIENT_ID=your_external_client_app_consumer_key
SF_CLIENT_SECRET=your_external_client_app_consumer_secret
SF_API_VERSION=66.0

# --- Web Push (PWA notifications) ---
# Generate a key pair once with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:you@example.com
# Shared secret the Salesforce Apex action must send as the X-Push-Secret header
PUSH_SHARED_SECRET=long_random_string
